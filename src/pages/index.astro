---
import Base from '../layouts/Base.astro';

const designs = [
  {
    href: '/designs/swiss',
    name: 'Swiss Grid',
    desc: '국제 타이포그래피 양식 — 디자인 바이블. 12컬럼 모듈 그리드 · 흑백+레드. 라이트.',
    tags: ['모듈 그리드', '타이포 인덱스', '그리드 오버레이(G)'],
  },
  {
    href: '/designs/kinetic',
    name: 'Kinetic Minimal',
    desc: 'Linear/Vercel급 다크 제품 미니멀 + 최상급 마이크로 인터랙션. 2026 IT 표준.',
    tags: ['스프링 인터랙션', '커서 글로우', '카운트업'],
  },
  {
    href: '/designs/premium',
    name: 'Premium Editorial',
    desc: '고급 브랜딩 × 기술감 있는 프리미엄 에디토리얼. 라이트. (Stripe·Locomotive 계열)',
    tags: ['에디토리얼 그리드', '매그네틱 CTA', '기술 마퀴'],
  },
  {
    href: '/designs/terminal',
    name: 'Terminal / Dev',
    desc: '코드 에디터 워크벤치 — 파일트리·⌘K 팔레트·타이프라이터·상태바. 고도화. 다크.',
    tags: ['VS Code UI', '⌘K 팔레트', 'stack.json'],
  },
  {
    href: '/designs/deepspace',
    name: 'Deep Space Warp',
    desc: '심우주 여행 — 스크롤하면 워프하듯 빨려 들어가는 몰입형 비행 연출. 별이 흐르고 섹션이 다가왔다 지나감. 다크.',
    tags: ['워프 스크롤', '3D 스타필드', '캔버스'],
  },
];
---

<Base title="Sihoon Cho — 디자인 비교">
  <main class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
    <header class="reveal max-w-2xl">
      <p class="font-mono text-xs tracking-widest text-neutral-500 uppercase">
        Design Comparison · 2026
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 sm:text-5xl">
        4가지 디자인 시안
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-neutral-600">
        아래에서 실제 동작하는 미리보기를 비교하세요. 카드를 클릭하면 전체 화면으로 열립니다.
        마음에 드는 시안을 알려주시면 그것을 최종 사이트로 확정합니다. (조합·수정도 가능)
      </p>
    </header>

    <div class="mt-14 grid gap-8 sm:grid-cols-2">
      {
        designs.map((d) => (
          <article class="reveal group">
            <a
              href={d.href}
              class="block overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-50 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl focus-visible:-translate-y-1 focus-visible:shadow-xl"
            >
              <div class="relative aspect-[16/10] w-full overflow-hidden border-b border-neutral-200 bg-white">
                <iframe
                  src={d.href}
                  title={`${d.name} 미리보기`}
                  loading="lazy"
                  scrolling="no"
                  tabindex="-1"
                  class="pointer-events-none absolute left-0 top-0 origin-top-left"
                  style="width:400%;height:400%;transform:scale(0.25);border:0;"
                />
                <span class="absolute right-3 top-3 rounded-full bg-neutral-900/80 px-3 py-1 font-mono text-xs text-white backdrop-blur transition-colors group-hover:bg-neutral-900">
                  전체 화면 보기 ↗
                </span>
              </div>
              <div class="flex items-start justify-between gap-4 p-5">
                <div>
                  <h2 class="text-xl font-semibold tracking-tight text-neutral-900">
                    {d.name}
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-neutral-600">{d.desc}</p>
                  <ul class="mt-3 flex flex-wrap gap-1.5">
                    {d.tags.map((t) => (
                      <li class="rounded-md bg-neutral-100 px-2 py-0.5 font-mono text-xs text-neutral-500">
                        {t}
                      </li>
                    ))}
                  </ul>
                </div>
                <span class="mt-1 shrink-0 text-neutral-400 transition-transform group-hover:translate-x-1">
                  →
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <footer class="reveal mt-20 border-t border-neutral-200 pt-8 text-sm text-neutral-500">
      <p>
        © 2026 Sihoon Cho · 조시훈 — 시안 비교용 페이지입니다. 확정 후 이 페이지는
        최종 디자인으로 교체됩니다.
      </p>
    </footer>
  </main>
</Base>

<style>
  main {
    background: #ffffff;
    min-height: 100vh;
  }
</style>

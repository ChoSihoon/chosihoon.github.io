---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { site, about, skills, projects } from '../data/site';

const hasEmail = site.email.trim().length > 0;
const social = Object.entries(site.links).filter(([, url]) => url.trim().length > 0);
const year = new Date().getFullYear();
---

<Layout>
  <Header />

  <main id="top" class="mx-auto max-w-5xl px-6">
    <!-- Hero -->
    <section class="flex min-h-screen flex-col justify-center gap-6 pt-20">
      <p class="text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase">
        {site.role}
      </p>
      <h1 class="text-5xl font-bold tracking-tight text-white sm:text-7xl">
        {site.name}
        <span class="block text-2xl font-normal text-gray-400 sm:text-3xl">
          {site.nameKo}
        </span>
      </h1>
      <p class="max-w-xl text-lg text-gray-400">{site.tagline}</p>
      <div class="flex flex-wrap gap-3 pt-2">
        <a
          href="#projects"
          class="rounded-full bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-2)] px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
        >
          프로젝트 보기
        </a>
        {
          hasEmail && (
            <a
              href={`mailto:${site.email}`}
              class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-medium text-gray-200 transition-colors hover:bg-white/5"
            >
              연락하기
            </a>
          )
        }
      </div>
    </section>

    <!-- About -->
    <section id="about" class="scroll-mt-24 border-t border-white/5 py-24">
      <h2 class="mb-8 text-sm font-medium tracking-widest text-gray-500 uppercase">
        {about.heading}
      </h2>
      <div class="max-w-2xl space-y-4 text-lg leading-relaxed text-gray-300">
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class="scroll-mt-24 border-t border-white/5 py-24">
      <h2 class="mb-8 text-sm font-medium tracking-widest text-gray-500 uppercase">
        Skills
      </h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {
          skills.map((s) => (
            <div>
              <h3 class="mb-3 text-base font-semibold text-white">{s.group}</h3>
              <ul class="flex flex-wrap gap-2">
                {s.items.map((item) => (
                  <li class="rounded-md bg-[var(--color-surface)] px-3 py-1 text-sm text-gray-300">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="scroll-mt-24 border-t border-white/5 py-24">
      <h2 class="mb-8 text-sm font-medium tracking-widest text-gray-500 uppercase">
        Projects
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          projects.map((proj) => (
            <article class="group rounded-xl border border-white/5 bg-[var(--color-surface)] p-6 transition-colors hover:border-white/15">
              <h3 class="mb-2 text-xl font-semibold text-white">{proj.title}</h3>
              <p class="mb-4 text-sm leading-relaxed text-gray-400">
                {proj.description}
              </p>
              <ul class="mb-4 flex flex-wrap gap-2">
                {proj.tags.map((tag) => (
                  <li class="text-xs font-medium text-[var(--color-accent)]">#{tag}</li>
                ))}
              </ul>
              <div class="flex gap-4 text-sm">
                {proj.link && (
                  <a
                    href={proj.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-300 hover:text-white"
                  >
                    Live ↗
                  </a>
                )}
                {proj.repo && (
                  <a
                    href={proj.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-300 hover:text-white"
                  >
                    Code ↗
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="scroll-mt-24 border-t border-white/5 py-24">
      <h2 class="mb-8 text-sm font-medium tracking-widest text-gray-500 uppercase">
        Contact
      </h2>
      <p class="mb-6 max-w-xl text-lg text-gray-300">
        새로운 기회나 협업에 열려 있습니다. 편하게 연락 주세요.
      </p>
      <div class="flex flex-wrap gap-4 text-sm">
        {
          hasEmail && (
            <a
              href={`mailto:${site.email}`}
              class="text-[var(--color-accent)] hover:underline"
            >
              {site.email}
            </a>
          )
        }
        {
          social.map(([key, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="capitalize text-gray-300 hover:text-white"
            >
              {key} ↗
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <footer class="border-t border-white/5 py-8">
    <p class="mx-auto max-w-5xl px-6 text-sm text-gray-600">
      © {year} {site.name}. Built with Astro & Tailwind.
    </p>
  </footer>
</Layout>

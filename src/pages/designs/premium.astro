</style>

<script>
  (() => {
    const root = document.querySelector<HTMLElement>('[data-premium]');
    if (!root) return;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── graceful fallback: drop any tech logo that fails to load ──
    root.querySelectorAll<HTMLImageElement>('img[data-techlogo]').forEach((i) =>
      i.addEventListener('error', () => i.remove())
    );

    // ── scroll-driven UI (one rAF-gated listener: header + progress + parallax + bg) ──
    const header = root.querySelector<HTMLElement>('[data-header]');
    const bar = root.querySelector<HTMLElement>('[data-progress]');
    const heroTitle = root.querySelector<HTMLElement>('.premium-hero__title');
    const animateScroll = !prefersReducedMotion && !!(bar || heroTitle);
    if (header || animateScroll) {
      // cached scroll range — recomputed on resize, not on every scroll frame
      let maxScroll = 0;
      const measureMaxScroll = () => {
        maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      };
      let ticking = false;
      const update = () => {
        ticking = false;
        const y = window.scrollY;
        if (header) header.classList.toggle('is-scrolled', y > 12);
        if (animateScroll) {
          const p = maxScroll > 0 ? Math.min(y / maxScroll, 1) : 0;
          // drive the editorial background via a CSS variable
          root.style.setProperty('--scroll', p.toFixed(4));
          if (bar) bar.style.transform = `scaleX(${p})`;
          if (heroTitle) {
            const offset = Math.min(y, 600);
            heroTitle.style.transform = `translateY(${offset * 0.08}px)`;
          }
        }
      };
      const requestUpdate = () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(update);
        }
      };
      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener(
        'resize',
        () => {
          measureMaxScroll();
          requestUpdate();
        },
        { passive: true }
      );
      measureMaxScroll();
      update();
    }

    // ── magnetic CTAs ──
    if (!prefersReducedMotion) {
      const mags = root.querySelectorAll<HTMLElement>('[data-magnetic]');
      mags.forEach((el) => {
        const inner = el.querySelector<HTMLElement>('[data-magnetic-inner]');
        const strength = 0.3;
        // rAF-gate pointer tracking: one layout read + style write per frame
        let frame = 0;
        let pointerX = 0;
        let pointerY = 0;
        const apply = () => {
          frame = 0;
          const r = el.getBoundingClientRect();
          const x = pointerX - r.left - r.width / 2;
          const y = pointerY - r.top - r.height / 2;
          el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
          if (inner)
            inner.style.transform = `translate(${x * strength * 0.4}px, ${y * strength * 0.4}px)`;
        };
        el.addEventListener('pointermove', (e) => {
          pointerX = e.clientX;
          pointerY = e.clientY;
          if (!frame) frame = requestAnimationFrame(apply);
        });
        const reset = () => {
          if (frame) {
            cancelAnimationFrame(frame);
            frame = 0;
          }
          el.style.transform = '';
          if (inner) inner.style.transform = '';
        };
        el.addEventListener('pointerleave', reset);
        el.addEventListener('blur', reset);
      });
    }

    // ── count-up stats ──
    const counters = root.querySelectorAll<HTMLElement>('[data-count]');
    if (counters.length) {
      const run = (el: HTMLElement) => {
        const target = Number(el.getAttribute('data-count')) || 0;
        if (prefersReducedMotion) {
          el.textContent = String(target);
          return;
        }
        const dur = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          const val = Math.round(target * eased);
          el.textContent = String(val);
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              run(e.target as HTMLElement);
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.6 }
      );
      counters.forEach((c) => io.observe(c));
    }

    // ── email copy ──
    const email = 'sihoon.cho.business@gmail.com';
    const copyBtn = root.querySelector<HTMLButtonElement>('[data-copy]');
    const feedback = root.querySelector<HTMLElement>('[data-copy-feedback]');
    const copyLabel = root.querySelector<HTMLElement>('[data-copy-label]');
    if (copyBtn) {
      let timer: number | undefined;
      const show = (msg: string) => {
        if (feedback) feedback.textContent = msg;
        if (copyLabel) copyLabel.textContent = '복사되었습니다!';
        window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          if (copyLabel) copyLabel.textContent = '복사';
          if (feedback) feedback.textContent = '';
        }, 2000);
      };
      const fallbackCopy = () => {
        try {
          const ta = document.createElement('textarea');
          ta.value = email;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          show('복사되었습니다!');
        } catch {
          show('복사에 실패했습니다. 직접 복사해 주세요.');
        }
      };
      copyBtn.addEventListener('click', async () => {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(email);
            show('복사되었습니다!');
          } else {
            fallbackCopy();
          }
        } catch {
          fallbackCopy();
        }
      });
    }
  })();
</script>

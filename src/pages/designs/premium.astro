---
import Base from '../../layouts/Base.astro';
import { site, about, stack, learning } from '../../data/site';
import { getTech, techLogo } from '../../data/tech';

// build a branded badge descriptor for a given tech name
function badge(name: string) {
  const logo = techLogo(name);
  const { color } = getTech(name);
  return { name, logo, color };
}

const year = 2026;
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#stack', label: 'Stack' },
  { href: '#learning', label: 'Learning' },
  { href: '#contact', label: 'Contact' },
];

// editorial stats derived from data (not github cards)
const toolCount = stack.reduce((n, g) => n + g.items.length, 0);
const stats = [
  { value: stack.length, suffix: '', label: 'Stack domains' },
  { value: toolCount, suffix: '+', label: 'Tools & frameworks' },
  { value: year, suffix: '', label: 'Shipping since', raw: true },
];

// marquee track: flatten primary stack into a single editorial stream
const marquee = stack.flatMap((g) => g.items);
---

<Base title="Sihoon Cho — Premium Editorial">
  <div class="premium" data-premium>
    <!-- scroll-driven editorial background -->
    <div class="premium-bg" aria-hidden="true" data-bg>
      <span class="premium-bg__orb premium-bg__orb--a"></span>
      <span class="premium-bg__orb premium-bg__orb--b"></span>
      <span class="premium-bg__grid"></span>
    </div>

    <!-- thin scroll-progress -->
    <div class="premium-progress" aria-hidden="true"><span data-progress></span></div>

    <!-- aria-live region for copy feedback -->
    <p class="premium-sr" role="status" aria-live="polite" data-copy-feedback></p>

    <!-- ───────── header ───────── -->
    <header class="premium-header" data-header role="banner">
      <div class="premium-header__inner">
        <a class="premium-brand" href="#top" aria-label={`${site.name} — 맨 위로`}>
          <span class="premium-brand__mark" aria-hidden="true"></span>
          <span class="premium-brand__name">{site.name}</span>
          <span class="premium-brand__ko" aria-hidden="true">{site.nameKo}</span>
        </a>
        <nav class="premium-nav" aria-label="Primary">
          {navLinks.map((l) => <a class="premium-nav__link" href={l.href}>{l.label}</a>)}
        </nav>
        <a class="premium-cta premium-cta--ghost" href="#contact" data-magnetic>
          <span data-magnetic-inner>연락하기</span>
        </a>
      </div>
    </header>

    <main id="top">
      <!-- ───────── hero ───────── -->
      <section class="premium-hero" aria-labelledby="hero-title">
        <div class="premium-shell premium-hero__grid">
          <div class="premium-hero__main">
            <p class="premium-eyebrow reveal">
              <span class="premium-mono">{site.role}</span>
              <span class="premium-eyebrow__loc premium-mono" aria-hidden="true">— Seoul, KR</span>
            </p>
            <h1 id="hero-title" class="premium-hero__title">
              <span class="premium-line reveal">Reliable</span>
              <span class="premium-line reveal" style="transition-delay:80ms">
                <em class="premium-serif">systems,</em>
              </span>
              <span class="premium-line reveal" style="transition-delay:160ms">shipped</span>
              <span class="premium-line premium-line--accent reveal" style="transition-delay:240ms">&amp; operated.</span>
            </h1>
            <div class="premium-hero__cta reveal" style="transition-delay:320ms">
              <a class="premium-cta premium-cta--solid" href="#contact" data-magnetic>
                <span data-magnetic-inner>연락하기</span>
                <svg class="premium-arrow" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"
                  ><path d="M3 8h9M8.5 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6"
                    stroke-linecap="round" stroke-linejoin="round"></path></svg
                >
              </a>
              <a
                class="premium-cta premium-cta--line"
                href={site.links.github}
                target="_blank"
                rel="noopener noreferrer"
                data-magnetic
              >
                <span data-magnetic-inner>GitHub ↗</span>
              </a>
            </div>
          </div>

          <aside class="premium-hero__aside reveal" style="transition-delay:200ms" aria-label="소개">
            <span class="premium-aside__rule" aria-hidden="true"></span>
            <p class="premium-hero__tagline">{site.tagline}</p>
            <p class="premium-hero__tagline premium-hero__tagline--en premium-mono">{site.taglineEn}</p>
            <p class="premium-hero__name-ko premium-mono" aria-hidden="true">{site.name} / {site.nameKo}</p>
          </aside>
        </div>

        <span class="premium-scrollcue premium-mono" aria-hidden="true">
          <span class="premium-scrollcue__line"></span>scroll
        </span>
      </section>

      <!-- ───────── about ───────── -->
      <section class="premium-section" id="about" aria-labelledby="about-title">
        <div class="premium-shell">
          <div class="premium-about__grid">
            <header class="premium-sechead reveal">
              <span class="premium-label premium-mono">About</span>
            </header>
            <div class="premium-about__body">
              <h2 id="about-title" class="premium-lead reveal">{about.lead}</h2>

              <ul class="premium-stats reveal" aria-label="Highlights at a glance">
                {
                  stats.map((s) => (
                    <li class="premium-stat">
                      <span class="premium-stat__num">
                        <span data-count={s.value} data-raw={s.raw ? '1' : '0'}>0</span>
                        {s.suffix}
                      </span>
                      <span class="premium-stat__label premium-mono">{s.label}</span>
                    </li>
                  ))
                }
              </ul>

              <ol class="premium-highlights" aria-label="Approach">
                {
                  about.highlights.map((h, i) => (
                    <li class="premium-hl reveal" style={`transition-delay:${i * 80}ms`}>
                      <span class="premium-hl__bul premium-mono" aria-hidden="true">→</span>
                      <span class="premium-hl__text">{h}</span>
                    </li>
                  ))
                }
              </ol>
            </div>
          </div>
        </div>
      </section>

      <!-- ───────── marquee ───────── -->
      <section class="premium-marquee" aria-hidden="true">
        <div class="premium-marquee__track" data-marquee>
          {
            [...marquee, ...marquee].map((it) => (
              <span class="premium-marquee__item">
                {it}
                <span class="premium-marquee__sep">/</span>
              </span>
            ))
          }
        </div>
      </section>

      <!-- ───────── tech stack ───────── -->
      <section class="premium-section premium-section--top" id="stack" aria-labelledby="stack-title">
        <div class="premium-shell">
          <header class="premium-sechead premium-sechead--row reveal">
            <span class="premium-label premium-mono">Tech Stack</span>
            <h2 id="stack-title" class="premium-sectitle">주력으로 다루는 기술</h2>
          </header>

          <div class="premium-stack">
            {
              stack.map((group, i) => (
                <article class="premium-stack__row reveal" style={`transition-delay:${(i % 4) * 50}ms`}>
                  <div class="premium-stack__cat">
                    <h3 class="premium-stack__catname">{group.category}</h3>
                    <span class="premium-stack__count premium-mono" aria-hidden="true">
                      {String(group.items.length).padStart(2, '0')}
                    </span>
                  </div>
                  <ul class="premium-chips" aria-label={group.category}>
                    {group.items.map((it) => {
                      const b = badge(it);
                      return (
                        <li
                          class="premium-chip"
                          style={`--brand:${b.color};background:${b.color}14;border-color:${b.color}40;`}
                        >
                          {b.logo && (
                            <img
                              class="premium-chip__logo"
                              data-techlogo
                              src={b.logo}
                              alt=""
                              width="16"
                              height="16"
                              loading="lazy"
                            />
                          )}
                          <span class="premium-chip__name">{b.name}</span>
                        </li>
                      );
                    })}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ───────── learning ───────── -->
      <section class="premium-section premium-section--muted" id="learning" aria-labelledby="learning-title">
        <div class="premium-shell">
          <header class="premium-sechead premium-sechead--row reveal">
            <span class="premium-label premium-mono">Learning</span>
            <h2 id="learning-title" class="premium-sectitle premium-sectitle--sm">탐색하고 익히는 중</h2>
          </header>

          <div class="premium-learn">
            {
              learning.map((group, i) => (
                <article class="premium-learn__col reveal" style={`transition-delay:${(i % 3) * 60}ms`}>
                  <h3 class="premium-learn__cat premium-mono">{group.category}</h3>
                  <ul class="premium-learn__items">
                    {group.items.map((it) => {
                      const b = badge(it);
                      return (
                        <li
                          class="premium-learn__badge"
                          style={`--brand:${b.color};background:${b.color}14;border-color:${b.color}40;`}
                        >
                          {b.logo && (
                            <img
                              class="premium-chip__logo"
                              data-techlogo
                              src={b.logo}
                              alt=""
                              width="16"
                              height="16"
                              loading="lazy"
                            />
                          )}
                          <span class="premium-chip__name">{b.name}</span>
                        </li>
                      );
                    })}
                  </ul>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ───────── contact ───────── -->
      <section class="premium-section premium-section--top" id="contact" aria-labelledby="contact-title">
        <div class="premium-shell">
          <div class="premium-contact__grid">
            <header class="premium-sechead reveal">
              <span class="premium-label premium-mono">Contact</span>
            </header>
            <div class="premium-contact__body">
              <h2 id="contact-title" class="premium-contact__title reveal">
                같이 만들 거리가 있다면,<br />
                <em class="premium-serif">편하게</em> 연락 주세요.
              </h2>

              <div class="premium-mailrow reveal">
                <a
                  class="premium-cta premium-cta--solid"
                  href="https://mail.google.com/mail/?view=cm&fs=1&to=sihoon.cho.business@gmail.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  data-magnetic
                >
                  <span data-magnetic-inner>Gmail로 보내기 ↗</span>
                </a>
                <button
                  type="button"
                  class="premium-mail"
                  data-copy
                  aria-label={`이메일 주소 복사: ${site.email}`}
                >
                  <span class="premium-mail__addr premium-mono">{site.email}</span>
                  <span class="premium-mail__hint premium-mono" data-copy-label>복사</span>
                </button>
              </div>

              <ul class="premium-social reveal">
                <li>
                  <a class="premium-ulink" href={site.links.github} target="_blank" rel="noopener noreferrer">
                    GitHub <span aria-hidden="true">↗</span>
                  </a>
                </li>
                <li>
                  <a class="premium-ulink" href={site.links.linkedin} target="_blank" rel="noopener noreferrer">
                    LinkedIn <span aria-hidden="true">↗</span>
                  </a>
                </li>
                <li>
                  <a class="premium-ulink" href={site.links.velog} target="_blank" rel="noopener noreferrer">
                    Velog <span aria-hidden="true">↗</span>
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="premium-footer">
      <div class="premium-shell premium-footer__inner">
        <span class="premium-mono">© {year} {site.name} · {site.nameKo}</span>
        <span class="premium-mono premium-footer__dim">Built with Astro</span>
      </div>
    </footer>
  </div>
</Base>

<style>
  .premium {
    --bg: #f2f1ef;
    --bg-2: #eceae5;
    --ink: #141414;
    --ink-soft: #3a3a38;
    --muted: #6e6c66;
    --faint: #9c9a92;
    --line: rgba(20, 20, 20, 0.12);
    --line-soft: rgba(20, 20, 20, 0.07);
    --accent: #1f4d66; /* deep ink-blue */
    --accent-deep: #163b50;
    --paper: #faf9f7;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    --spring: cubic-bezier(0.2, 0.85, 0.25, 1.05);

    --scroll: 0; /* 0 → 1 scroll progress, driven by JS */
    position: relative;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    font-family: var(--font-sans);
    overflow-x: clip;
  }

  /* ── scroll-driven background ── */
  .premium-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .premium-bg__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.5;
    will-change: transform;
  }
  .premium-bg__orb--a {
    width: 46vmax;
    height: 46vmax;
    top: -14vmax;
    right: -10vmax;
    background: radial-gradient(circle at 50% 50%, rgba(31, 77, 102, 0.14), transparent 68%);
    transform: translateY(calc(var(--scroll) * -16vh));
  }
  .premium-bg__orb--b {
    width: 52vmax;
    height: 52vmax;
    bottom: -20vmax;
    left: -16vmax;
    background: radial-gradient(circle at 50% 50%, rgba(150, 120, 90, 0.12), transparent 70%);
    transform: translateY(calc(var(--scroll) * 22vh));
  }
  /* faint editorial grid that drifts + fades as you scroll */
  .premium-bg__grid {
    position: absolute;
    inset: -10% -5%;
    background-image: linear-gradient(rgba(20, 20, 20, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 20, 20, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    opacity: calc(0.5 - var(--scroll) * 0.3);
    transform: translateY(calc(var(--scroll) * -8vh));
  }
  /* keep all real content above the background */
  .premium-header,
  .premium main,
  .premium-footer,
  .premium-progress,
  .premium-sr {
    position: relative;
    z-index: 1;
  }
  /* screen-reader-only live region */
  .premium-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .premium-mono {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .premium-serif {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  /* ── scroll progress ── */
  .premium-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 2px;
    z-index: 80;
    background: transparent;
    pointer-events: none;
  }
  .premium-progress span {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: 0 50%;
    background: var(--accent);
  }

  /* ── shell ── */
  .premium-shell {
    width: 100%;
    max-width: 76rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3.5rem);
    position: relative;
  }

  /* ── header ── */
  .premium-header {
    position: sticky;
    top: 0;
    z-index: 70;
    border-bottom: 1px solid transparent;
    transition: background-color 0.4s var(--ease), border-color 0.4s var(--ease),
      backdrop-filter 0.4s var(--ease);
  }
  .premium-header.is-scrolled {
    background: rgba(242, 241, 239, 0.82);
    backdrop-filter: blur(10px) saturate(120%);
    border-bottom-color: var(--line);
  }
  .premium-header__inner {
    max-width: 76rem;
    margin-inline: auto;
    padding: clamp(1rem, 2vw, 1.3rem) clamp(1.25rem, 5vw, 3.5rem);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: padding 0.4s var(--ease);
  }
  .premium-header.is-scrolled .premium-header__inner {
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }
  .premium-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-grotesk);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .premium-brand__mark {
    width: 12px;
    height: 12px;
    background: var(--accent);
    transition: transform 0.6s var(--spring), background-color 0.3s var(--ease);
  }
  .premium-brand:hover .premium-brand__mark {
    transform: rotate(45deg) scale(1.15);
    background: var(--accent-deep);
  }
  .premium-brand__ko {
    color: var(--faint);
    font-size: 0.82rem;
    font-weight: 500;
    font-family: var(--font-sans);
  }
  .premium-nav {
    margin-left: auto;
    display: none;
    gap: 0.2rem;
  }
  .premium-nav__link {
    position: relative;
    padding: 0.4rem 0.7rem;
    font-size: 0.82rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.25s var(--ease);
  }
  .premium-nav__link::after {
    content: '';
    position: absolute;
    left: 0.7rem;
    right: 0.7rem;
    bottom: 0.15rem;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.35s var(--spring);
  }
  .premium-nav__link:hover {
    color: var(--ink);
  }
  .premium-nav__link:hover::after {
    transform: scaleX(1);
  }
  @media (min-width: 860px) {
    .premium-nav {
      display: inline-flex;
    }
  }

  /* ── CTAs ── */
  .premium-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.62rem 1.05rem;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border-radius: 3px;
    border: 1px solid var(--line);
    color: var(--ink);
    background: transparent;
    will-change: transform;
    transition: transform 0.4s var(--spring), background-color 0.3s var(--ease),
      border-color 0.3s var(--ease), color 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .premium-cta--ghost {
    margin-left: auto;
  }
  @media (min-width: 860px) {
    .premium-cta--ghost {
      margin-left: 0;
    }
  }
  .premium-cta--ghost:hover {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--paper);
  }
  .premium-cta--solid {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .premium-cta--solid:hover {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 10px 30px -12px rgba(31, 77, 102, 0.6);
  }
  .premium-cta--line:hover {
    border-color: var(--ink);
    background: var(--paper);
  }
  .premium-arrow {
    transition: transform 0.4s var(--spring);
  }
  .premium-cta:hover .premium-arrow {
    transform: translateX(4px);
  }

  /* ── hero ── */
  .premium-hero {
    position: relative;
    padding: clamp(4.5rem, 14vh, 9rem) 0 clamp(3.5rem, 9vh, 6rem);
    min-height: 84vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .premium-hero__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    grid-template-columns: 1fr;
    align-items: end;
  }
  @media (min-width: 900px) {
    .premium-hero__grid {
      grid-template-columns: minmax(0, 1.6fr) minmax(15rem, 0.85fr);
    }
  }
  .premium-eyebrow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    color: var(--accent);
    margin-bottom: clamp(1.4rem, 3vw, 2.2rem);
  }
  .premium-eyebrow__loc {
    color: var(--faint);
  }
  .premium-hero__title {
    font-family: var(--font-grotesk);
    font-weight: 500;
    line-height: 0.96;
    letter-spacing: -0.04em;
    font-size: clamp(3rem, 11vw, 7.5rem);
    margin: 0;
    color: var(--ink);
  }
  .premium-line {
    display: block;
  }
  .premium-line--accent {
    color: var(--accent);
  }
  .premium-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  .premium-hero__aside {
    position: relative;
    padding-top: 0.4rem;
  }
  .premium-aside__rule {
    display: block;
    width: 2.6rem;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.3rem;
  }
  .premium-hero__tagline {
    font-size: clamp(1rem, 1.5vw, 1.12rem);
    line-height: 1.62;
    color: var(--ink-soft);
    margin: 0 0 0.9rem;
    max-width: 26rem;
  }
  .premium-hero__tagline--en {
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--muted);
  }
  .premium-hero__name-ko {
    margin: 1.4rem 0 0;
    color: var(--faint);
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .premium-scrollcue {
    margin-top: clamp(2.5rem, 6vh, 4rem);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--faint);
    padding-inline: clamp(1.25rem, 5vw, 3.5rem);
  }
  .premium-scrollcue__line {
    width: 38px;
    height: 1px;
    background: var(--faint);
    position: relative;
    overflow: hidden;
  }
  .premium-scrollcue__line::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 16px;
    background: var(--accent);
    animation: premium-slide 2.2s var(--ease) infinite;
  }
  @keyframes premium-slide {
    from {
      transform: translateX(-16px);
    }
    to {
      transform: translateX(38px);
    }
  }

  /* ── sections ── */
  .premium-section {
    position: relative;
    padding: clamp(3.5rem, 9vh, 7rem) 0;
  }

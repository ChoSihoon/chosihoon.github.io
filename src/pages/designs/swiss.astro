---
import Base from '../../layouts/Base.astro';
import { site, about, stack, learning } from '../../data/site';

const year = 2026;
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#stack', label: 'Stack' },
  { href: '#learning', label: 'Learning' },
  { href: '#contact', label: 'Contact' },
];
// zero-padded ordinals used purely as Swiss compositional numerals (not section labels)
const pad = (n: number) => String(n).padStart(2, '0');
---

<Base title="Sihoon Cho — Swiss Grid">
  <div class="swiss" id="top">
    <!-- scroll-driven systematic background — column grid + baseline rules
         that parallax-shift subtly on scroll. Restrained, never flashy. -->
    <div class="swiss-bg" aria-hidden="true">
      <div class="swiss-shell swiss-bg__cols" data-bg-cols>
        {Array.from({ length: 12 }).map(() => <span class="swiss-bg__col"></span>)}
      </div>
      <div class="swiss-bg__baselines" data-bg-lines></div>
    </div>

    <!-- visible 12-column grid overlay — a deliberate design element (toggle: G) -->
    <div class="swiss-grid-overlay" aria-hidden="true">
      <div class="swiss-shell swiss-grid-overlay__inner">
        {Array.from({ length: 12 }).map(() => <span class="swiss-grid-overlay__col"></span>)}
      </div>
    </div>

    <!-- ───────── header ───────── -->
    <header class="swiss-header" role="banner">
      <div class="swiss-shell swiss-header__inner">
        <a class="swiss-brand" href="#top" aria-label={`${site.name} — 맨 위로`}>
          <svg class="swiss-brand__mark" viewBox="0 0 32 32" width="15" height="15" aria-hidden="true">
            <circle class="swiss-brand__tg-b" cx="16" cy="16" r="16" />
            <path
              class="swiss-brand__tg-r"
              d="M1.66 8.91 A16 16 0 0 1 30.34 23.09 A8 8 0 0 0 16 16 A8 8 0 0 1 1.66 8.91 Z"
            />
          </svg>
          <span class="swiss-brand__name">{site.name}</span>
          <span class="swiss-brand__ko">{site.nameKo}</span>
        </a>
        <nav class="swiss-nav" aria-label="주요 메뉴">
          {navLinks.map((l) => (
            <a class="swiss-nav__link" href={l.href}>
              <span class="swiss-nav__label">{l.label}</span>
            </a>
          ))}
        </nav>
        <span class="swiss-header__meta swiss-mono" aria-hidden="true">EST. 2026 · SEOUL</span>
      </div>
    </header>

    <main>
      <!-- ───────── hero ───────── -->
      <section class="swiss-hero" aria-labelledby="hero-title">
        <div class="swiss-shell">
          <div class="swiss-hero__top reveal">
            <span class="swiss-mono swiss-label">{site.role}</span>
            <span class="swiss-mono swiss-label swiss-label--num" aria-hidden="true">{pad(1)}/{pad(5)}</span>
          </div>
          <hr class="swiss-rule swiss-rule--bold reveal" />
          <h1 id="hero-title" class="swiss-hero__title">
            <span class="swiss-hero__line reveal">Reliable</span>
            <span class="swiss-hero__line reveal">servers,<span class="swiss-hero__accent" aria-hidden="true"></span></span>
            <span class="swiss-hero__line reveal">operated in<br /><span class="swiss-hero__red">the cloud.</span></span>
          </h1>
          <div class="swiss-hero__foot">
            <p class="swiss-hero__tagline reveal" lang="ko">{site.tagline}</p>
            <p class="swiss-hero__tagline swiss-hero__tagline--en reveal" lang="en">{site.taglineEn}</p>
          </div>
          <hr class="swiss-rule reveal" />
          <div class="swiss-hero__index reveal" aria-hidden="true">
            <span class="swiss-mono">{site.name}</span>
            <span class="swiss-mono">{site.nameKo}</span>
            <span class="swiss-mono">{site.role}</span>
            <span class="swiss-mono">↓ SCROLL</span>
          </div>
        </div>
      </section>

      <!-- ───────── marquee — single restrained kinetic element ───────── -->
      <div class="swiss-marquee" aria-hidden="true">
        <div class="swiss-marquee__track" data-marquee>
          {Array.from({ length: 2 }).map(() => (
            <span class="swiss-marquee__group">
              <span>Backend</span><span class="swiss-marquee__sep">/</span>
              <span>Cloud</span><span class="swiss-marquee__sep">/</span>
              <span>DevOps</span><span class="swiss-marquee__sep">/</span>
              <span>Java · Spring</span><span class="swiss-marquee__sep">/</span>
              <span>Python</span><span class="swiss-marquee__sep">/</span>
              <span>AWS · GCP</span><span class="swiss-marquee__sep">/</span>
            </span>
          ))}
        </div>
      </div>

      <!-- ───────── about ───────── -->
      <section id="about" class="swiss-section" aria-labelledby="about-title">
        <div class="swiss-shell swiss-section__inner">
          <div class="swiss-section__head reveal">
            <h2 id="about-title" class="swiss-section__title">About</h2>
            <span class="swiss-mono swiss-label swiss-label--num" aria-hidden="true">{pad(2)}/{pad(5)}</span>
          </div>
          <hr class="swiss-rule swiss-rule--bold reveal" />
          <div class="swiss-about">
            <p class="swiss-about__lead reveal" lang="ko">{about.lead}</p>
            <ol class="swiss-about__list" role="list">
              {about.highlights.map((h, i) => (
                <li class="swiss-about__item reveal" style={`--i:${i}`}>
                  <span class="swiss-about__num swiss-mono" aria-hidden="true">{pad(i + 1)}</span>
                  <span class="swiss-about__text" lang="ko">{h}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <!-- ───────── tech stack — typographic index/table ───────── -->
      <section id="stack" class="swiss-section swiss-section--dark" aria-labelledby="stack-title">
        <div class="swiss-shell swiss-section__inner">
          <div class="swiss-section__head reveal">
            <h2 id="stack-title" class="swiss-section__title">Tech Stack</h2>
            <span class="swiss-mono swiss-label swiss-label--num" aria-hidden="true">{pad(3)}/{pad(5)}</span>
          </div>
          <hr class="swiss-rule swiss-rule--bold swiss-rule--inv reveal" />
          <div class="swiss-index">
            <div class="swiss-index__header swiss-mono" aria-hidden="true">
              <span>No.</span>
              <span>Category</span>
              <span>Items</span>
            </div>
            {stack.map((g, i) => (
              <div class="swiss-index__row reveal" style={`--i:${i}`}>
                <span class="swiss-index__num swiss-mono" aria-hidden="true">{pad(i + 1)}</span>
                <h3 class="swiss-index__cat">{g.category}</h3>
                <ul class="swiss-index__items">
                  {g.items.map((it) => (
                    <li class="swiss-index__item">{it}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ───────── learning — secondary ───────── -->
      <section id="learning" class="swiss-section swiss-section--muted" aria-labelledby="learning-title">
        <div class="swiss-shell swiss-section__inner">
          <div class="swiss-section__head reveal">
            <h2 id="learning-title" class="swiss-section__title swiss-section__title--sm">Learning</h2>
            <span class="swiss-mono swiss-label swiss-label--num" aria-hidden="true">{pad(4)}/{pad(5)}</span>
          </div>
          <hr class="swiss-rule reveal" />
          <p class="swiss-learning__note swiss-mono reveal">학습 중 · 탐색 중 · 복습 중</p>
          <div class="swiss-learning">
            {learning.map((g, i) => (
              <div class="swiss-learning__row reveal" style={`--i:${i}`}>
                <h3 class="swiss-learning__cat">{g.category}</h3>
                <ul class="swiss-learning__items">
                  {g.items.map((it) => (
                    <li class="swiss-learning__item">{it}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ───────── contact ───────── -->
      <section id="contact" class="swiss-section" aria-labelledby="contact-title">
        <div class="swiss-shell swiss-section__inner">
          <div class="swiss-section__head reveal">
            <h2 id="contact-title" class="swiss-section__title">Contact</h2>
            <span class="swiss-mono swiss-label swiss-label--num" aria-hidden="true">{pad(5)}/{pad(5)}</span>
          </div>
          <hr class="swiss-rule swiss-rule--bold reveal" />
          <div class="swiss-contact">
            <div class="swiss-contact__main reveal">
              <p class="swiss-contact__kicker swiss-mono">함께 일하고 싶으신가요?</p>
              <p class="swiss-contact__email" data-email>{site.email}</p>
              <div class="swiss-contact__actions">
                <a
                  class="swiss-btn swiss-btn--red"
                  href={`https://mail.google.com/mail/?view=cm&fs=1&to=${site.email}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span class="swiss-btn__label">Gmail로 보내기</span>
                  <span class="swiss-btn__mark" aria-hidden="true">↗</span>
                </a>
                <button type="button" class="swiss-btn" data-copy aria-label="이메일 주소 복사하기">
                  <span class="swiss-btn__label">이메일 복사</span>
                  <span class="swiss-btn__mark" aria-hidden="true">[ ]</span>
                </button>
              </div>
              <p class="swiss-contact__feedback swiss-mono" data-feedback role="status" aria-live="polite"></p>
            </div>

            <nav class="swiss-contact__links reveal" aria-label="외부 링크">
              <a class="swiss-link" href={site.links.github} target="_blank" rel="noopener noreferrer">
                <span class="swiss-link__idx swiss-mono" aria-hidden="true">{pad(1)}</span>
                <span class="swiss-link__name">GitHub</span>
                <span class="swiss-link__arrow" aria-hidden="true">↗</span>
              </a>
              <a class="swiss-link" href={site.links.linkedin} target="_blank" rel="noopener noreferrer">
                <span class="swiss-link__idx swiss-mono" aria-hidden="true">{pad(2)}</span>
                <span class="swiss-link__name">LinkedIn</span>
                <span class="swiss-link__arrow" aria-hidden="true">↗</span>
              </a>
              <a class="swiss-link" href={site.links.velog} target="_blank" rel="noopener noreferrer">
                <span class="swiss-link__idx swiss-mono" aria-hidden="true">{pad(3)}</span>
                <span class="swiss-link__name">Velog</span>
                <span class="swiss-link__arrow" aria-hidden="true">↗</span>
              </a>
            </nav>
          </div>
        </div>
      </section>
    </main>

    <!-- ───────── footer ───────── -->
    <footer class="swiss-footer" role="contentinfo">
      <div class="swiss-shell swiss-footer__inner">
        <hr class="swiss-rule swiss-rule--bold" />
        <div class="swiss-footer__row">
          <span class="swiss-footer__copy swiss-mono">© {year} Sihoon Cho · 조시훈</span>
          <span class="swiss-footer__sys swiss-mono" aria-hidden="true">INTERNATIONAL TYPOGRAPHIC STYLE</span>
          <a class="swiss-footer__top swiss-mono" href="#top">↑ TOP</a>
        </div>
      </div>
    </footer>
  </div>
</Base>

<style>
  /* ─────────────────────────────────────────────
     SWISS GRID — International Typographic Style
     한지(韓紙) ivory + warm black + 태극 적·청 accents
     ───────────────────────────────────────────── */
  .swiss {
    --paper: #f3eddf;
    --paper-2: #f8f4ea;
    --ink: #18140d;
    --red: #c0392f;
    --blue: #14467c;
    --hair: rgba(24, 20, 13, 0.16);
    --hair-inv: rgba(248, 244, 234, 0.18);
    --gutter: 24px;
    --margin: clamp(20px, 5vw, 80px);

    /* ── modular typographic scale ──
       A single, deliberate harmonic progression (~1.32 ratio).
       Every type size on the page is drawn from these steps —
       no arbitrary one-off sizes. Müller-Brockmann discipline. */
    --step--1: clamp(0.72rem, 0.7rem + 0.1vw, 0.78rem); /* mono labels / captions */
    --step-0: clamp(0.95rem, 0.92rem + 0.18vw, 1.05rem); /* body */
    --step-1: clamp(1.18rem, 1.05rem + 0.5vw, 1.45rem); /* lead-secondary */
    --step-2: clamp(1.5rem, 1.25rem + 1vw, 2rem); /* sub-display */
    --step-3: clamp(1.9rem, 1.4rem + 1.8vw, 2.75rem); /* display-3 */
    --step-4: clamp(2.4rem, 1.6rem + 3vw, 3.75rem); /* section titles */
    --step-5: clamp(3rem, 2rem + 4vw, 4.75rem); /* large display */
    --step-6: clamp(3.4rem, 2.2rem + 5.4vw, 6.5rem); /* hero — measured, in-grid */

    position: relative;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-sans);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* shared 12-col container */
  .swiss-shell {
    width: 100%;
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: var(--margin);
  }

  /* ── scroll-driven systematic background ── */
  .swiss-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  /* faint always-present 12-column structure; parallaxes vertically on scroll */
  .swiss-bg__cols {
    position: absolute;
    inset: -8vh 0;
    height: 116vh;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--gutter);
    will-change: transform;
  }
  .swiss-bg__col {
    border-left: 1px solid rgba(24, 20, 13, 0.045);
    border-right: 1px solid rgba(24, 20, 13, 0.045);
  }
  /* signature 태극 moment: one emphasized column rendered as a faint
     red edge + a faint blue edge — a subtle 적·청 interplay in the grid */
  .swiss-bg__col:nth-child(7) {
    border-left-color: rgba(192, 57, 47, 0.08);
    border-right-color: rgba(20, 70, 124, 0.08);
  }
  /* horizontal baseline rules; parallaxes at a different rate for depth */
  .swiss-bg__baselines {
    position: absolute;
    inset: -12vh 0;
    height: 124vh;
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(24, 20, 13, 0.035) 0,
      rgba(24, 20, 13, 0.035) 1px,
      transparent 1px,
      transparent 96px
    );
    will-change: transform;
  }

  /* ── visible grid overlay ── */
  .swiss-grid-overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .swiss[data-grid='on'] .swiss-grid-overlay {
    opacity: 1;
  }
  .swiss-grid-overlay__inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--gutter);
    height: 100%;
  }
  .swiss-grid-overlay__col {
    border-left: 1px solid rgba(20, 70, 124, 0.16);
    border-right: 1px solid rgba(20, 70, 124, 0.16);
  }

  /* ── rules ── */
  .swiss-rule {
    border: 0;
    border-top: 1px solid var(--hair);
    margin: clamp(18px, 3vw, 32px) 0;
  }
  .swiss-rule--bold {
    border-top: 3px solid var(--ink);
  }
  .swiss-rule--inv {
    border-top-color: var(--paper);
  }

  /* ── mono / labels ── */
  .swiss-mono {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
  .swiss-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* ── header ── */
  .swiss-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    backdrop-filter: saturate(120%) blur(6px);
    border-bottom: 1px solid var(--hair);
  }
  /* 헤더가 fixed이므로 본문을 헤더 높이만큼 내림 */
  .swiss main {
    padding-top: 64px;
  }
  .swiss-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gutter);
    height: 64px;
  }
  .swiss-brand {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
  }
  .swiss-brand__mark {
    width: 15px;
    height: 15px;
    align-self: center;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .swiss-brand__tg-r {
    fill: var(--red);
  }
  .swiss-brand__tg-b {
    fill: var(--blue);
  }
  .swiss-brand:hover .swiss-brand__mark {
    transform: scale(1.08);
  }
  .swiss-brand__name {
    font-family: var(--font-grotesk);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .swiss-brand__ko {
    font-size: 0.82rem;
    color: rgba(24, 20, 13, 0.55);
  }
  .swiss-nav {
    display: none;
    gap: clamp(14px, 2vw, 30px);
  }
  @media (min-width: 720px) {
    .swiss-nav {
      display: flex;
    }
  }
  .swiss-nav__link {
    position: relative;
    text-decoration: none;
    color: var(--ink);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding-bottom: 2px;
  }
  .swiss-nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .swiss-nav__link:hover::after,
  .swiss-nav__link:focus-visible::after {
    transform: scaleX(1);
  }
  .swiss-header__meta {
    display: none;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: rgba(24, 20, 13, 0.5);
  }
  @media (min-width: 980px) {
    .swiss-header__meta {
      display: inline;
    }
  }

  /* ── hero ── */
  .swiss-hero {
    position: relative;
    z-index: 1;
    padding-top: clamp(48px, 9vw, 120px);
    padding-bottom: clamp(28px, 5vw, 56px);
  }
  .swiss-hero__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: rgba(24, 20, 13, 0.7);
  }
  /* compositional index numerals — structural marker → 태극 청 */
  .swiss-label--num {
    color: var(--red);
  }
  /* 다크 패널(Tech Stack)에서는 청 번호를 한지쪽으로 끌어올려 가시성 확보 */
  .swiss-section--dark .swiss-label--num {
    color: color-mix(in srgb, var(--red) 55%, var(--paper));
  }
  .swiss-hero__title {
    font-family: var(--font-grotesk);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
    /* disciplined display step of the modular scale — measured, not screen-filling */
    font-size: var(--step-6);
    margin: clamp(10px, 2vw, 24px) 0 clamp(28px, 5vw, 56px);
    text-transform: none;
    max-width: 18ch;
  }
  @media (min-width: 900px) {
    .swiss-hero__title {
      /* hero occupies a disciplined column span, not the full bleed */
      max-width: none;
      width: 75%;
    }
  }
  .swiss-hero__line {
    display: block;
    position: relative;
  }
  .swiss-hero__red {
    color: var(--blue);
  }
  .swiss-hero__accent {
    display: inline-block;
    width: clamp(28px, 6vw, 90px);
    height: clamp(14px, 2.4vw, 34px);
    background: var(--red);
    margin-left: clamp(10px, 2vw, 28px);
    vertical-align: middle;
  }
  .swiss-hero__foot {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(10px, 2vw, 16px);
    max-width: 62ch;
    margin-left: auto;
  }
  @media (min-width: 720px) {
    .swiss-hero__foot {
      grid-template-columns: repeat(12, 1fr);
    }
    .swiss-hero__tagline {
      grid-column: 7 / 13;
    }
  }
  .swiss-hero__tagline {
    font-size: var(--step-1);
    line-height: 1.5;
    max-width: 44ch;
  }
  .swiss-hero__tagline--en {
    color: rgba(24, 20, 13, 0.55);
    font-size: var(--step-0);
  }
  .swiss-hero__index {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(14px, 4vw, 48px);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(24, 20, 13, 0.55);
  }

  /* ── marquee ── */
  .swiss-marquee {
    position: relative;
    z-index: 1;
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--hair);
    overflow: hidden;
    background: var(--paper);
  }
  .swiss-marquee__track {
    display: inline-flex;
    white-space: nowrap;
    will-change: transform;
    animation: swiss-scroll 34s linear infinite;
  }
  .swiss-marquee:hover .swiss-marquee__track {
    animation-play-state: paused;
  }
  .swiss-marquee__group {
    display: inline-flex;
    align-items: center;
    gap: clamp(16px, 3vw, 40px);
    padding: 14px clamp(16px, 3vw, 40px) 14px 0;
    font-family: var(--font-grotesk);
    font-weight: 600;
    font-size: var(--step-2);
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }
  .swiss-marquee__sep {
    color: var(--red);
  }
  @keyframes swiss-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  /* ── sections ── */
  .swiss-section {
    position: relative;
    z-index: 1;
    /* transparent so the faint scroll-driven grid reads through the paper */
    background: transparent;
    padding-block: clamp(56px, 9vw, 128px);
  }
  .swiss-section--dark {
    background: var(--ink);
    color: var(--paper);
  }
  .swiss-section--muted {
    background: var(--paper-2);
  }
  .swiss-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--gutter);
  }
  .swiss-section__title {
    font-family: var(--font-grotesk);
    font-weight: 700;
    /* prominent within the scale, but deliberately below the hero step */
    font-size: var(--step-4);
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .swiss-section__title--sm {
    font-size: var(--step-3);
  }

  /* ── about ── */
  .swiss-about {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 5vw, 56px);
  }
  @media (min-width: 900px) {
    .swiss-about {
      grid-template-columns: repeat(12, 1fr);
      gap: var(--gutter);
    }
    .swiss-about__lead {
      grid-column: 1 / 6;
    }
    .swiss-about__list {
      grid-column: 7 / 13;
    }
  }
  .swiss-about__lead {
    font-family: var(--font-grotesk);
    font-weight: 500;
    font-size: var(--step-2);
    line-height: 1.28;
    letter-spacing: -0.02em;
  }
  .swiss-about__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .swiss-about__item {
    display: grid;
    grid-template-columns: 3.2em 1fr;
    gap: 16px;
    align-items: baseline;
    padding: clamp(14px, 2vw, 20px) 0;
    border-top: 1px solid var(--hair);
  }
  .swiss-about__item:last-child {
    border-bottom: 1px solid var(--hair);
  }
  .swiss-about__num {
    font-size: 0.78rem;
    color: var(--red);
  }
  .swiss-about__text {
    font-size: var(--step-0);
    line-height: 1.55;
  }

  /* ── stack index/table ── */
  .swiss-index {
    width: 100%;
  }
  .swiss-index__header {
    display: none;
    grid-template-columns: 3.5em 9em 1fr;
    gap: var(--gutter);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--paper) 50%, transparent);
    padding-bottom: 14px;
  }
  @media (min-width: 760px) {
    .swiss-index__header {
      display: grid;
    }
  }
  .swiss-index__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px var(--gutter);
    padding: clamp(18px, 2.6vw, 28px) 0;
    border-top: 1px solid var(--hair-inv);
    transition: background 0.3s ease;
  }
  .swiss-index__row:last-child {
    border-bottom: 1px solid var(--hair-inv);
  }
  @media (min-width: 760px) {
    .swiss-index__row {
      grid-template-columns: 3.5em 9em 1fr;
      align-items: baseline;
    }
  }
  .swiss-index__row:hover {
    background: color-mix(in srgb, var(--paper) 5%, transparent);
  }
  /* category numerals on the dark panel — 청, lifted toward hanji for contrast */
  .swiss-index__num {
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--red) 55%, var(--paper));
  }
  .swiss-index__cat {
    font-family: var(--font-grotesk);
    font-weight: 700;
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  .swiss-index__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 0;
    align-items: baseline;
  }
  .swiss-index__item {
    font-size: var(--step-0);
    line-height: 1.4;
    padding-right: 14px;
    margin-right: 14px;
    position: relative;
    color: color-mix(in srgb, var(--paper) 82%, transparent);
    transition: color 0.2s ease;
  }
  .swiss-index__item::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0.18em;
    bottom: 0.18em;
    width: 1px;
    background: color-mix(in srgb, var(--paper) 22%, transparent);
  }
  .swiss-index__item:last-child {
    margin-right: 0;
    padding-right: 0;
  }
  .swiss-index__item:last-child::after {
    display: none;
  }
  .swiss-index__item:hover {
    color: color-mix(in srgb, var(--blue) 70%, var(--paper));
  }

  /* ── learning ── */
  .swiss-learning__note {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(24, 20, 13, 0.5);
    margin-bottom: clamp(18px, 3vw, 30px);
  }
  .swiss-learning {
    display: grid;
    grid-template-columns: 1fr;
  }
  .swiss-learning__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px var(--gutter);
    padding: clamp(14px, 2vw, 20px) 0;
    border-top: 1px solid var(--hair);
  }
  .swiss-learning__row:last-child {
    border-bottom: 1px solid var(--hair);
  }
  @media (min-width: 700px) {
    .swiss-learning__row {
      grid-template-columns: 11em 1fr;
      align-items: baseline;
    }
  }
  .swiss-learning__cat {
    font-family: var(--font-grotesk);
    font-weight: 600;
    font-size: var(--step-0);
    color: rgba(24, 20, 13, 0.72);
    letter-spacing: -0.005em;
  }
  .swiss-learning__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 0;
  }
  .swiss-learning__item {
    font-size: var(--step--1);
    color: rgba(24, 20, 13, 0.62);
    padding-right: 12px;
    margin-right: 12px;
    position: relative;
  }
  .swiss-learning__item::after {
    content: '·';
    position: absolute;
    right: 2px;
    color: rgba(24, 20, 13, 0.3);
  }
  .swiss-learning__item:last-child {
    margin-right: 0;
    padding-right: 0;
  }
  .swiss-learning__item:last-child::after {
    display: none;
  }

  /* ── contact ── */
  .swiss-contact {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(36px, 6vw, 64px);
  }
  @media (min-width: 900px) {
    .swiss-contact {
      grid-template-columns: repeat(12, 1fr);
      gap: var(--gutter);
    }
    .swiss-contact__main {
      grid-column: 1 / 9;
    }
    .swiss-contact__links {
      grid-column: 10 / 13;
    }
  }
  .swiss-contact__kicker {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: clamp(12px, 2vw, 18px);
  }
  .swiss-contact__email {
    font-family: var(--font-grotesk);
    font-weight: 700;
    font-size: var(--step-3);
    letter-spacing: -0.025em;
    line-height: 1.02;
    word-break: break-word;
    margin-bottom: clamp(22px, 4vw, 36px);
  }
  .swiss-contact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .swiss-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: transparent;
    color: var(--ink);
    border: 2px solid var(--ink);
    padding: 12px 18px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .swiss-btn:hover,
  .swiss-btn:focus-visible {
    background: var(--ink);
    color: var(--paper);
  }
  .swiss-btn--red {
    border-color: var(--blue);
    color: var(--blue);
  }
  .swiss-btn--red:hover,
  .swiss-btn--red:focus-visible {
    background: var(--blue);
    color: var(--paper);
  }
  .swiss-btn__mark {
    font-size: 0.85em;
  }
  .swiss-contact__feedback {
    min-height: 1.4em;
    margin-top: 14px;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--blue);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .swiss-contact__feedback.is-on {
    opacity: 1;
    transform: none;
  }
  .swiss-contact__links {
    display: flex;
    flex-direction: column;
    align-self: start;
  }
  .swiss-link {
    display: grid;
    grid-template-columns: 2.4em 1fr auto;
    align-items: baseline;
    gap: 10px;
    padding: clamp(14px, 2vw, 18px) 0;
    border-top: 1px solid var(--hair);
    text-decoration: none;
    color: var(--ink);
    transition: padding-left 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .swiss-link:last-child {
    border-bottom: 1px solid var(--hair);
  }
  /* 태극 interplay: blue link indices shift to red on hover */
  .swiss-link:hover,
  .swiss-link:focus-visible {
    padding-left: 8px;
    color: var(--blue);
  }
  .swiss-link__idx {
    font-size: 0.72rem;
    color: var(--red);
  }
  .swiss-link:hover .swiss-link__idx,
  .swiss-link:focus-visible .swiss-link__idx {
    color: var(--blue);
  }
  .swiss-link__name {
    font-family: var(--font-grotesk);
    font-weight: 600;
    font-size: var(--step-1);
    letter-spacing: -0.01em;
  }
  .swiss-link__arrow {
    font-size: 1rem;
  }

  /* ── footer ── */
  .swiss-footer {
    position: relative;
    z-index: 1;
    background: transparent;
    padding-bottom: clamp(28px, 4vw, 48px);
  }
  .swiss-footer__row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding-top: 18px;
  }
  /* 좌·우 1fr 동일 폭 + 가운데 확실한 중앙 정렬 (콘텐츠 폭에 영향받지 않음) */
  .swiss-footer__copy {
    grid-column: 1;
    justify-self: start;
    text-align: left;
  }
  .swiss-footer__sys {
    grid-column: 2;
    justify-self: center;
    text-align: center;
  }
  .swiss-footer__top {
    grid-column: 3;
    justify-self: end;
    text-align: right;
  }
  .swiss-footer__copy,
  .swiss-footer__sys,
  .swiss-footer__top {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(24, 20, 13, 0.6);
  }
  .swiss-footer__sys {
    display: none;
  }
  @media (min-width: 760px) {
    .swiss-footer__sys {
      display: inline;
    }
  }
  .swiss-footer__top {
    text-decoration: none;
    color: var(--ink);
    transition: color 0.2s ease;
  }
  .swiss-footer__top:hover {
    color: var(--blue);
  }

  /* ── focus-visible (global, system-respecting) ── */
  .swiss a:focus-visible,
  .swiss button:focus-visible {
    outline: 2px solid var(--red);
    outline-offset: 3px;
  }

  /* ── staggered reveal for gridded rows ── */
  .swiss .swiss-about__item.reveal,
  .swiss .swiss-index__row.reveal,
  .swiss .swiss-learning__row.reveal {
    transition-delay: calc(var(--i, 0) * 60ms);
  }

  /* ── prefersReducedMotion motion ── */
  @media (prefers-reduced-motion: reduce) {
    .swiss-marquee__track {
      animation: none;
    }
    .swiss-brand__mark {
      transition: none;
    }
    .swiss .reveal {
      transition: none !important;
    }
    /* background stays static — no parallax */
    .swiss-bg__cols,
    .swiss-bg__baselines {
      transform: none !important;
      will-change: auto;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector<HTMLElement>('.swiss');
    if (!root) return;

    /* ── visible grid overlay: toggle with the "G" key (deliberate design tool) ── */
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'g' || e.key === 'G') {
        const tag = (e.target as HTMLElement)?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        root.dataset.grid = root.dataset.grid === 'on' ? 'off' : 'on';
      }
    });

    /* ── email: copy to clipboard with visible feedback ── */
    const email =
      document.querySelector<HTMLElement>('[data-email]')?.textContent?.trim() ||
      'sihoon.cho.business@gmail.com';
    const copyBtn = document.querySelector<HTMLButtonElement>('[data-copy]');
    const feedback = document.querySelector<HTMLElement>('[data-feedback]');
    let timer: number | undefined;

    const flash = (msg: string) => {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.classList.add('is-on');
      if (timer) window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        feedback.classList.remove('is-on');
      }, 2000);
    };

    const fallbackCopy = (text: string) => {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'absolute';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      let ok = false;
      try {
        ok = document.execCommand('copy');
      } catch {
        ok = false;
      }
      document.body.removeChild(ta);
      return ok;
    };

    copyBtn?.addEventListener('click', async () => {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(email);
          flash('복사되었습니다!');
        } else {
          flash(fallbackCopy(email) ? '복사되었습니다!' : '복사 실패 — ' + email);
        }
      } catch {
        flash(fallbackCopy(email) ? '복사되었습니다!' : '복사 실패 — ' + email);
      }
    });

    /* ── scroll-driven background: rAF-throttled parallax of the grid system ── */
    const cols = document.querySelector<HTMLElement>('[data-bg-cols]');
    const lines = document.querySelector<HTMLElement>('[data-bg-lines]');
    if (!prefersReducedMotion && (cols || lines)) {
      let ticking = false;
      const render = () => {
        const y = window.scrollY || 0;
        // restrained, systematic offsets — columns drift slowly, baselines a touch more
        if (cols) cols.style.transform = `translate3d(0, ${(y * -0.04).toFixed(2)}px, 0)`;
        if (lines) lines.style.transform = `translate3d(0, ${(y * 0.06).toFixed(2)}px, 0)`;
        ticking = false;
      };
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(render);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      render();
    }

    /* ── marquee: seamless duplication already in markup; nothing else needed ── */
  })();
</script>

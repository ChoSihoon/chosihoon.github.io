---
import { site } from '../data/site';

const nav = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-[var(--color-bg)]/70 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Primary"
  >
    <a href="#top" class="text-sm font-semibold tracking-tight text-white">
      {site.name}
    </a>
    <ul class="hidden items-center gap-8 text-sm text-gray-400 sm:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="transition-colors hover:text-white"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={site.links.github}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-gray-400 transition-colors hover:text-white"
    >
      GitHub ↗
    </a>
  </nav>
</header>
